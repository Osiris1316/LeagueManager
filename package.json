{
  "name": "league-manager",
  "private": true,
  "scripts": {
    "dev:api": "cd packages/api && pnpm dev",
    "dev:web": "cd packages/web && pnpm dev",
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:web\"",
    "build:web": "cd packages/web && pnpm build",
    "migrate": "npx tsx scripts/migrate.ts",
    "seed": "npx tsx scripts/seed.ts",
    "deploy:api": "npx wrangler deploy",
    "deploy:web": "cd packages/web && pnpm build && npx wrangler pages deploy dist --project-name=league-manager"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3",
    "wrangler": "^4.14.4"
  }
}
